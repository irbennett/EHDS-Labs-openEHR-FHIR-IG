                                <term_definitions code="at0001">
                                    <items id="text">Care plan name</items>
                                    <items id="description">The name , preferably coded of the Care plan with which this journey is associated, and against which the composition was updated.</items>
                                </term_definitions>
                                <term_definitions code="at0002">
                                    <items id="text">Care plan identifier</items>
                                    <items id="description">The identifier , preferably coded, of the Care plan with which this journey is associated, and against which the composition was updated.</items>
                                </term_definitions>
                                <term_definitions code="at0003">
                                    <items id="text">Patient journey identifier</items>
                                    <items id="description">A patient-journey specific identifier i.e unique to a patient's journey along a specific care pathway.</items>
